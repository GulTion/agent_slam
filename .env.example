# Network
WSS_URL=wss://your-match-server.example.com/ws?payload=<JWT_TOKEN_INCLUDED_IN_URL>

# OpenAI compatible base URL (no API key needed, proxy handles auth transparently)
BASE_URL=https://your-openai-compatible-proxy.example.com/v1

# Models
MODEL_RESEARCHER=gemini-3.0-flash
MODEL_DEBATER=gemini-3.1-pro

# Tavily (comma-separated keys, one will be chosen at random per search call)
TAVILY_API_KEYS=tvly-key1,tvly-key2,tvly-key3

# LangSmith observability
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=agent-slam-2026
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_pt_...

# Logging (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
